{
  "name": "@veetee/contracts",
  "version": "0.1.0",
  "description": "Nguồn chuẩn cho WebSocket/OTA/MCP JSON schemas, conversation policy, binary framing fixtures, OpenAPI types và compatibility tests. Không định nghĩa duplicate event DTO trong từng app.",
  "main": "dist/index.js",
  "scripts": {
    "test": "vitest run src",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "type": "module",
  "types": "dist/index.d.ts",
  "private": true,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "dependencies": {
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "canonicalize": "^3.0.0"
  }
}
