# Copy to .env for local development. Never commit real credentials.
VEETEE_ENVIRONMENT=development
VEETEE_HOST=127.0.0.1
VEETEE_PORT=8000
VEETEE_RELOAD=true
VEETEE_LOG_LEVEL=INFO
VEETEE_LOG_JSON=false

VEETEE_DATABASE_URL=postgresql://veetee:veetee_dev_only@127.0.0.1:5432/veetee
VEETEE_INTEGRATION_DATABASE_URL=postgresql://veetee:veetee_dev_only@127.0.0.1:5432/veetee_test
VEETEE_REDIS_URL=redis://127.0.0.1:6379/0
VEETEE_MANAGER_API_URL=http://127.0.0.1:8001
VEETEE_CONVERSATION_EVENT_RETENTION_DAYS=7
VEETEE_RESOURCE_SIGNING_KEY_ID=veetee-dev-release-2026-01
VEETEE_RESOURCE_SIGNING_PUBLIC_KEY_HEX=
VEETEE_TELEMETRY_QUEUE_CAPACITY=256
VEETEE_TELEMETRY_BATCH_SIZE=32
VEETEE_TELEMETRY_FLUSH_SECONDS=0.25
VEETEE_TELEMETRY_SHUTDOWN_SECONDS=1

VEETEE_9ROUTER_BASE_URL=http://127.0.0.1:20128/v1
VEETEE_9ROUTER_API_KEY=
VEETEE_9ROUTER_MODEL=cx/gpt-5.6-terra
VEETEE_9ROUTER_REASONING_EFFORT=none
VEETEE_LLM_PREWARM=true
VEETEE_LLM_PREWARM_SECONDS=12
VEETEE_PLANNER_SECONDS=8

VEETEE_MODELS_ROOT=models
VEETEE_ASR_THREADS=2
VEETEE_VAD_THREADS=1
VEETEE_VAD_THRESHOLD=0.5
VEETEE_VAD_RELEASE_THRESHOLD=0.35
VEETEE_VAD_MIN_SILENCE_MS=400
VEETEE_TTS_THREADS=2
VEETEE_TTS_VOICE="Trúc Ly"
VEETEE_TTS_OUTPUT_SAMPLE_RATE=24000
VEETEE_TTS_APPLY_WATERMARK=true
VEETEE_GOODBYE_TEXT=Tạm biệt, hẹn gặp lại.
VEETEE_DEFAULT_LOCALE=vi-VN
VEETEE_DEFAULT_PERSONA="You are Veetee, a concise voice assistant. Reply in the user's language using one to three short spoken sentences. Do not use Markdown or expose hidden reasoning."
VEETEE_INPUT_SAMPLE_RATE=16000
VEETEE_WIRE_SAMPLE_RATE=24000
VEETEE_MAX_UTTERANCE_SECONDS=20
VEETEE_FIRST_INPUT_SECONDS=15
VEETEE_BETWEEN_TURNS_SECONDS=30
VEETEE_CLOSING_GRACE_SECONDS=5
VEETEE_ASR_SECONDS=8

# Optional Docker infrastructure only.
VEETEE_POSTGRES_USER=veetee
VEETEE_POSTGRES_PASSWORD=veetee_dev_only
VEETEE_POSTGRES_DB=veetee
VEETEE_POSTGRES_PORT=5432
VEETEE_REDIS_PORT=6379
VEETEE_MINIO_ROOT_USER=veetee
VEETEE_MINIO_ROOT_PASSWORD=veetee_minio_dev_only
VEETEE_MINIO_API_PORT=9000
VEETEE_MINIO_CONSOLE_PORT=9001
