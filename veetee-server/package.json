{
  "name": "@veetee/server-root",
  "version": "1.0.0",
  "description": "Backend monorepo của Veetee. Realtime voice path và management control plane được tách riêng nhưng dùng cùng contracts.",
  "scripts": {
    "test": "npm run test --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "docs:validate": "node scripts/validate-docs.mjs",
    "dev:voice": "uv run --project apps/voice-server python apps/voice-server/main.py",
    "test:voice": "uv run --project apps/voice-server pytest",
    "test:voice:local-e2e": "uv run --project apps/voice-server python scripts/e2e_voice_loop.py",
    "test:web:e2e": "npm run test:e2e --workspace @veetee/manager-web",
    "lint:voice": "uv run --project apps/voice-server ruff check apps/voice-server && uv run --project apps/voice-server mypy --config-file apps/voice-server/pyproject.toml -p veetee_voice_server",
    "models:prepare": "uv run --project apps/voice-server python scripts/prepare_local_ai.py",
    "models:prepare-native": "uv run --project apps/voice-server python scripts/prepare_native_tts.py",
    "models:benchmark": "HF_HUB_OFFLINE=1 uv run --project apps/voice-server python scripts/benchmark_local_ai.py",
    "providers:probe:9router": "uv run --project apps/voice-server python scripts/probe_nine_router.py",
    "infra:up": "docker compose -f compose.infra.yaml up -d postgres redis",
    "infra:down": "docker compose -f compose.infra.yaml down",
    "infra:host:prepare": "bash scripts/infra-host-prepare.sh",
    "infra:host:up": "bash scripts/infra-host-up.sh",
    "infra:host:down": "bash scripts/infra-host-down.sh"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "private": true,
  "workspaces": [
    "apps/manager-api",
    "apps/manager-web",
    "packages/contracts",
    "packages/provider-sdk"
  ],
  "devDependencies": {
    "@types/node": "^24.13.3",
    "typescript": "^5.9.3",
    "vitest": "^3.2.7"
  },
  "allowScripts": {
    "@node-rs/argon2@2.0.2": true,
    "@prisma/client@6.19.3": true,
    "@prisma/engines@6.19.3": true,
    "esbuild@0.28.1": true,
    "prisma@6.19.3": true
  }
}
