DATABASE_URL=postgresql://veetee@127.0.0.1:5432/veetee?schema=public
REDIS_URL=redis://127.0.0.1:6379/1
VEETEE_MANAGER_PORT=8001
VEETEE_MANAGER_HOST=127.0.0.1
VEETEE_MANAGER_CORS_ORIGIN=http://127.0.0.1:8081
VEETEE_MANAGER_PUBLIC_URL=http://127.0.0.1:8001
VEETEE_VOICE_WS_URL=ws://127.0.0.1:8000/veetee/v1/
VEETEE_VOICE_LAB_WS_URL=ws://127.0.0.1:8000/veetee/lab/v1/
VEETEE_VOICE_INTERNAL_URL=http://127.0.0.1:8000
VEETEE_FIRMWARE_VERSION=0.1.0
VEETEE_FIRMWARE_URL=
VEETEE_RESOURCE_VERSION=0.0.0
VEETEE_RESOURCE_MANIFEST_URL=
VEETEE_RESOURCE_MANIFEST_ID=
VEETEE_ARTIFACT_ROOT=data/artifacts
VEETEE_MAX_RESOURCE_ARTIFACT_BYTES=67108864
VEETEE_ACTIVATION_MESSAGE_TEMPLATE={code}

# Generate independent random values; never reuse these in production.
VEETEE_AUTH_SECRET=replace-with-at-least-32-random-characters
VEETEE_LAB_TOKEN_SECRET=replace-with-an-independent-32-character-random-value
VEETEE_DEVICE_TOKEN_SECRET=replace-with-an-independent-32-character-random-value
VEETEE_MASTER_KEY=replace-with-a-base64-encoded-32-byte-key
VEETEE_INTERNAL_SERVICE_TOKEN=replace-with-a-random-service-token

# Optional one-time bootstrap identity for a fresh database.
VEETEE_BOOTSTRAP_TENANT_SLUG=veetee-local
VEETEE_BOOTSTRAP_TENANT_NAME=Veetee Local
VEETEE_BOOTSTRAP_ADMIN_EMAIL=owner@veetee.local
VEETEE_BOOTSTRAP_ADMIN_PASSWORD=replace-before-start
VEETEE_BOOTSTRAP_ADMIN_NAME=Veetee Owner
